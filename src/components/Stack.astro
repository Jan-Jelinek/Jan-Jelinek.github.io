---
import Card from "./common/Card.astro";
import SectionTitle from './common/SectionTitle.astro';

interface Category {
  label: string;
  items: string[];
}

const categories: Category[] = [
  {
    label: "languages",
    items: ["Python", "C#", "Rust", "Javascript"],
  },
  {
    label: "frameworks",
    items: ["ASP.NET", "Blazor", "Odoo", "Django"],
  },
  {
    label: "databases",
    items: ["PostgreSQL", "SQLite", "MongoDB"],
  },
  {
    label: "infrastructure & tools",
    items: ["Azure", "Docker", "CI/CD pipelines", "Git", "Jira"],
  },
];
---

<section id="stack" class="mx-auto max-w-[1080px] scroll-mt-20 px-7 pb-[clamp(64px,9vw,110px)]">
  <SectionTitle prefix="02" label="stack"/>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    {
      categories.map((category) => (
        <Card padMap="sm">
          <div class="mb-[12px] flex items-center gap-[10px] border-b border-white/[0.08] pb-[6px]">
            <span class="h-[5px] w-[5px] rotate-45 bg-accent"></span>
            <span class="text-[12px] font-semibold uppercase tracking-[0.18em] text-fg">
              {category.label}
            </span>
          </div>
          <div class="flex flex-wrap gap-[7px]">
            {category.items.map((item) => (
              <span class="rounded-[5px] border border-white/[0.08] bg-white/[0.03] px-[11px] py-[5px] text-[12.5px] text-muted transition-colors duration-200 hover:border-accent/40 hover:text-fg">
                {item}
              </span>
            ))}
          </div>
        </Card>
      ))
    }
  </div>
</section>
