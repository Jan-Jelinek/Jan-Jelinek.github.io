---
const { email, linkedin, github } = Astro.props;

const tagline = "I translate complex business workflows into clean, reliable software.";
---

<section
  id="top"
  class="mx-auto flex min-h-[calc(84vh-60px)] max-w-[1080px] scroll-mt-20 items-center justify-center px-7 py-[clamp(48px,8vw,96px)]"
>
  <div class="flex max-w-[760px] flex-col items-center text-center">
    <!-- Name -->
    <h1
      class="text-[clamp(44px,8vw,82px)] font-bold leading-[1.02] tracking-[-0.02em] text-fg"
    >
      Jan Jelinek
    </h1>

    <!-- Role -->
    <p class="mt-[14px] text-[12.5px] uppercase tracking-[0.24em] text-accent">
      fullstack developer &middot; solutions architect
    </p>

    <!-- Tagline -->
    <p class="mt-[18px] text-[clamp(15px,1.6vw,17px)] leading-[1.7] text-muted">
      {tagline}
    </p>

    <!-- Links -->
    <div class="mt-7 flex flex-wrap items-center justify-center gap-3 text-sm">
      <a
        href={`${github}`}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-[6px] border border-white/[0.14] px-[14px] py-2 text-[#cfd5dd] transition-colors hover:border-accent hover:text-fg"
      >
        github
      </a>
      <a
        href={`${linkedin}`}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-[6px] border border-white/[0.14] px-[14px] py-2 text-[#cfd5dd] transition-colors hover:border-accent hover:text-fg"
      >
        linkedin
      </a>
      <a
        href={`mailto:${email}`}
        class="rounded-[6px] border border-white/[0.14] px-[14px] py-2 text-[#cfd5dd] transition-colors hover:border-accent hover:text-fg"
      >
        {email}
      </a>
    </div>
  </div>
</section>
