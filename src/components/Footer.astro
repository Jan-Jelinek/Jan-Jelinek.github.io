---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.06] bg-bg/70 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1080px] flex-wrap items-center justify-between gap-[14px] px-7 py-[26px] text-[12.5px] text-faint">
    <span>&copy; {year} Jan Jelinek</span>

    <span class="text-faint/60">designed with the help of Claude</span>

    <button class="cursor-pointer text-muted transition-colors hover:text-accent" onclick="window.scroll({top: 0, left: 0, behavior: 'smooth'})">
      back to top &uarr;
    </button>  
  </div>
</footer>